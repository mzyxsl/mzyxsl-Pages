---
import { Icon } from 'astro-icon/components';
---
<div class="fixed top-4 right-4 z-50">
    <div class="relative">
        <!-- 主按钮 -->
        <button id="themeToggleBtn" class="w-10 h-10 rounded-full bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border border-gray-200 dark:border-gray-700 shadow-md hover:shadow-lg hover:bg-gray-100/80 dark:hover:bg-gray-700/90 transition-all duration-100 flex items-center justify-center cursor-pointer active:bg-gray-200/80 dark:active:bg-gray-600/80 active:scale-95">
      <span id="themeIconLight" class="hidden">
        <Icon name="material-symbols:light-mode" class="w-5 h-5 text-blue-500" />
      </span>
            <span id="themeIconDark" class="hidden">
        <Icon name="material-symbols:dark-mode" class="w-5 h-5 text-cyan-400" />
      </span>
            <span id="themeIconAuto">
        <Icon name="material-symbols:brightness-auto" class="w-5 h-5 text-blue-500 dark:text-cyan-400" />
      </span>
        </button>

        <!-- 下拉菜单（不动） -->
        <div id="themeDropdownMenu" class="absolute right-0 mt-2 w-30 bg-white/90 dark:bg-gray-800/90 backdrop-blur-md rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden hidden">
            <button data-theme="light" class="theme-option w-full text-left px-4 py-2 text-sm hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2 transition-colors active:bg-gray-200/80 dark:active:bg-gray-600/80">
                <Icon name="material-symbols:light-mode" class="w-4 h-4 flex-shrink-0 text-blue-500 dark:text-cyan-400" />
                浅色模式
            </button>
            <button data-theme="dark" class="theme-option w-full text-left px-4 py-2 text-sm hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2 transition-colors active:bg-gray-200/80 dark:active:bg-gray-600/80">
                <Icon name="material-symbols:dark-mode" class="w-4 h-4 flex-shrink-0 text-blue-500 dark:text-cyan-400" />
                深色模式
            </button>
            <button data-theme="auto" class="theme-option w-full text-left px-4 py-2 text-sm hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2 transition-colors active:bg-gray-200/80 dark:active:bg-gray-600/80">
                <Icon name="material-symbols:brightness-auto" class="w-4 h-4 flex-shrink-0 text-blue-500 dark:text-cyan-400" />
                跟随系统
            </button>
        </div>
    </div>
</div>

<script is:inline>
    (function () {
        const STORAGE_KEY = 'theme-preference';
        const toggleBtn = document.getElementById('themeToggleBtn');
        const dropdownMenu = document.getElementById('themeDropdownMenu');
        const lightSpan = document.getElementById('themeIconLight');
        const darkSpan = document.getElementById('themeIconDark');
        const autoSpan = document.getElementById('themeIconAuto');
        const themeOptions = document.querySelectorAll('.theme-option');

        if (!toggleBtn || !dropdownMenu || !lightSpan || !darkSpan || !autoSpan) return;

        const getSystemTheme = () =>
            window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

        const showIcon = (mode) => {
            lightSpan.classList.toggle('hidden', mode !== 'light');
            darkSpan.classList.toggle('hidden', mode !== 'dark');
            autoSpan.classList.toggle('hidden', mode !== 'auto');
        };

        const applyTheme = (mode) => {
            let theme;
            if (mode === 'auto') {
                theme = getSystemTheme();
                localStorage.removeItem(STORAGE_KEY);
            } else {
                theme = mode;
                localStorage.setItem(STORAGE_KEY, theme);
            }
            document.documentElement.classList.toggle('dark', theme === 'dark');
            showIcon(mode);

            themeOptions.forEach((opt) => {
                const optMode = opt.getAttribute('data-theme');
                const isActive = optMode === mode;
                opt.classList.toggle('bg-blue-50', isActive);
                opt.classList.toggle('dark:bg-cyan-800/50', isActive);
                opt.classList.toggle('text-blue-500', isActive);
                opt.classList.toggle('dark:text-cyan-400', isActive);
            });
        };

        const getCurrentMode = () => {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored === 'light') return 'light';
            if (stored === 'dark') return 'dark';
            return 'auto';
        };

        const toggleDropdown = () => {
            if (dropdownMenu.classList.contains('hidden')) {
                dropdownMenu.classList.remove('hidden');
                void dropdownMenu.offsetHeight;
                dropdownMenu.classList.remove('dropdown-animate-out', 'dropdown-animate-in');
                dropdownMenu.classList.add('dropdown-animate-in');
                dropdownMenu.addEventListener('animationend', () => dropdownMenu.classList.remove('dropdown-animate-in'), { once: true });
            } else {
                closeDropdownWithAnimation();
            }
        };

        const onOptionClick = (e) => {
            const mode = e.currentTarget.getAttribute('data-theme');
            applyTheme(mode);
            closeDropdownWithAnimation();
        };

        const closeDropdownWithAnimation = () => {
            if (!dropdownMenu.classList.contains('hidden')) {
                dropdownMenu.classList.remove('dropdown-animate-in');
                dropdownMenu.classList.add('dropdown-animate-out');
                dropdownMenu.addEventListener('animationend', () => {
                    dropdownMenu.classList.add('hidden');
                    dropdownMenu.classList.remove('dropdown-animate-out');
                }, { once: true });
            }
        };

        const handleClickOutside = (e) => {
            if (!toggleBtn.contains(e.target) && !dropdownMenu.contains(e.target)) {
                closeDropdownWithAnimation();
            }
        };

        toggleBtn.addEventListener('click', toggleDropdown);
        themeOptions.forEach(opt => opt.addEventListener('click', onOptionClick));
        document.addEventListener('click', handleClickOutside);

        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const handleSystemChange = (e) => {
            if (getCurrentMode() === 'auto') {
                const newTheme = e.matches ? 'dark' : 'light';
                document.documentElement.classList.toggle('dark', newTheme === 'dark');
                showIcon('auto');
                themeOptions.forEach(opt => {
                    const isActive = opt.getAttribute('data-theme') === 'auto';
                    opt.classList.toggle('bg-blue-50', isActive);
                    opt.classList.toggle('dark:bg-cyan-800/50', isActive);
                    opt.classList.toggle('text-blue-500', isActive);
                    opt.classList.toggle('dark:text-cyan-400', isActive);
                });
            }
        };
        media.addEventListener('change', handleSystemChange);

        const initialMode = getCurrentMode();
        applyTheme(initialMode);
    })();
</script>