---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import avatar from '../assets/images/avatar.png';
import SocialCard from '../components/SocialCard.astro';

const currentYear = new Date().getFullYear();
---

<Layout>

	<div class="text-center mb-12 md:mb-16">
		<div class="inline-flex items-center justify-center w-28 h-28 md:w-32 md:h-32 rounded-full bg-white/60 dark:bg-gray-800/60 backdrop-blur-sm shadow-xl ring-4 ring-white/50 dark:ring-gray-700/50 mb-5 overflow-hidden transition-transform duration-300 hover:scale-105">
			<Picture src={avatar} formats={['avif','webp']} alt="avatar" priority class="w-full h-full object-contain"/>
		</div>
		<h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-normal py-1 text-blue-500 dark:text-cyan-400">
			mzyxsl
		</h1>
		<p class="text-lg text-gray-600 dark:text-gray-400 mt-3 max-w-md mx-auto">
			我太菜了
		</p>
		<div class="flex flex-wrap justify-center gap-2 mt-4">
			<span class="px-3 py-1 text-sm rounded-full bg-blue-100 text-blue-600 dark:bg-cyan-900/50 dark:text-cyan-300">Minecraft</span>
			<span class="px-3 py-1 text-sm rounded-full bg-blue-100 text-blue-600 dark:bg-cyan-900/50 dark:text-cyan-300">垃圾搬运工</span>
		</div>

	</div>

	<h1 class="text-center text-2xl font-bold text-blue-500 dark:text-cyan-400 mb-5">联系方式</h1>
	<div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6 mx-auto max-w-4xl">
		<SocialCard icon="fa6-brands:qq" iconColor="text-blue-400" title="QQ" description="3305114625" type="copy" />
		<SocialCard href="https://t.me/mzyxsl114514/" description="@mzyxsl114514" icon="fa6-brands:telegram" iconColor="text-[#0088CC] dark:text-[#2AABEE]" title="Telegram" type="link" />
		<SocialCard href="https://steamcommunity.com/id/mzyxsl/" description="名字已消失了" icon="fa6-brands:steam" iconColor="dark:text-gray-200" title="Steam" type="link" />
		<SocialCard href="https://github.com/mzyxsl" icon="fa6-brands:github" iconColor="text-gray-900 dark:text-gray-200" title="GitHub" description="@mzyxsl" type="link" />
		<SocialCard href="https://space.bilibili.com/49827389" icon="fa6-brands:bilibili" iconColor="text-sky-500" title="bilibili" description="名字已消失了" type="link" />
		<SocialCard href="mailto:mzyxsl@mzyxsl.com" icon="fa6-solid:envelope" iconColor="text-amber-500" title="Email" description="mzyxsl@mzyxsl.com" type="link" />
	</div>
	
	<footer class="mt-30 text-center text-sm text-gray-700 dark:text-gray-400 border-t border-gray-200 dark:border-gray-800 pt-8 bg-transparent">
		<p>Copyright &copy; 2017 - {currentYear} mzyxsl. All rights reserved.</p>
	</footer>
</Layout>