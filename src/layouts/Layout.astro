---
import '../styles/global.css'
import '@fontsource/noto-sans';
import 'overlayscrollbars/styles/overlayscrollbars.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { Icon } from 'astro-icon/components';
const description = "mzyxsl的个人主页";
const avatarUrl = new URL('/avatar.png', Astro.site).href;
---

<!doctype html>
<html lang="zh-CN">
<head>
	<script>
		import { OverlayScrollbars } from 'overlayscrollbars';
		const init = () => {
			// 初始化滚动条
			OverlayScrollbars(document.body, {
				scrollbars: {
					autoHide: 'move',
					autoHideDelay: 300,
					clickScroll: true,
				},
			});

			document.body.classList.add('os-theme-custom');

			const syncDarkClass = () => {
				const isDark = document.documentElement.classList.contains('dark');
				if (isDark) {
					document.body.classList.add('dark');
				} else {
					document.body.classList.remove('dark');
				}
			};

			syncDarkClass();

			// 监听 html 上的 dark 类变化
			const observer = new MutationObserver(() => {
				syncDarkClass();
			});
			observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init);
		} else {
			init();
		}
	</script>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" href="/favicon.ico" />
	<meta name="generator" content={Astro.generator} />
	<title>mzyxsl - 个人主页</title>
	<meta name="description" content={description} />
	<meta property="og:type" content="website" />
	<meta property="og:url" content={Astro.url}>
	<meta property="og:site_name" content="mzyxsl" />
	<meta property="og:title" content="mzyxsl - 个人主页" />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={avatarUrl} />
	<meta property="og:image:alt" content="mzyxsl avatar" />
	<meta property="og:image:type" content="image/png" />
	<meta property="og:image:width" content="512" />
	<meta property="og:image:height" content="512" />
	<meta property="twitter:card" content="summary_large_image" />
	<meta property="twitter:url" content={Astro.url} />
	<meta property="twitter:title" content="mzyxsl - 个人主页" />
	<meta property="twitter:description" content={description} />
	<meta property="twitter:image" content={avatarUrl} />

	<script is:inline>
		(function() {
			console.log('好想涩涩');
			const storageKey = 'theme-preference';
			const getSystemTheme = () => window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			let theme = localStorage.getItem(storageKey);
			if (!theme) theme = getSystemTheme();
			if (theme === 'dark') document.documentElement.classList.add('dark');
			else document.documentElement.classList.remove('dark');
		})();
	</script>
</head>
<body>
<!--
    #    # ###### #   # #    #  ####  #
    ##  ##     #   # #   #  #  #      #
    # ## #    #     #     ##    ####  #
    #    #   #      #     ##        # #
    #    #  #       #    #  #  #    # #
    #    # ######   #   #    #  ####  ######
-->
<div id="toast-icon-templates" style="display:none" aria-hidden="true">
  <span id="toast-icon-success">
    <Icon name="material-symbols:check-circle" class="w-4 h-4 text-green-500" />
  </span>
	<span id="toast-icon-error">
    <Icon name="material-symbols:error" class="w-4 h-4 text-red-500" />
  </span>
</div>
<ThemeToggle />
<main class="max-w-full px-4 py-12 md:py-20 animate-fade-in-up">
	<slot />
</main>
</body>
</html>
